# Public browser key injected into generated HTML by scripts/inject-env.js
GOOGLE_MAPS_PUBLIC_KEY=your_google_maps_browser_key

# Server-side key for /api/get-fare (Distance Matrix / Routes)
GOOGLE_MAPS_API_KEY=your_google_maps_server_key

# Ride request email delivery (/api/ride-request)
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxx
RIDE_REQUEST_FROM_EMAIL=Luxival <noreply@luxival.com>
RIDE_REQUEST_TO_EMAILS=support@luxival.com,Olakunleshopeju@luxival.com
# Optional extra CC recipient
RIDE_REQUEST_CC_EMAIL=

# Optional Supabase environment variables used by other automation endpoints
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key
