# Environment variables for Luxival Audit Backend
# Copy this to .env and fill in real values. Never commit .env to git.

# CORS — comma-separated list of allowed origins
ALLOWED_ORIGINS=https://luxival.com,http://localhost:3000

# SumUp webhook signing secret (get from SumUp dashboard → Webhooks)
SUMUP_WEBHOOK_SECRET=your_sumup_webhook_secret_here

# Supabase (optional — for lead capture)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your_supabase_anon_key_here
