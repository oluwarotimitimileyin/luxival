{
  "cleanUrls": true,
  "trailingSlash": false,
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "Strict-Transport-Security",
          "value": "max-age=31536000; includeSubDomains; preload"
        },
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "Referrer-Policy",
          "value": "strict-origin-when-cross-origin"
        },
        {
          "key": "Permissions-Policy",
          "value": "geolocation=(), microphone=(), camera=()"
        }
      ]
    }
  ],
  "redirects": [
    {
      "source": "/:path*.html",
      "destination": "/:path*",
      "permanent": true
    },
    {
      "source": "/design-services",
      "destination": "/pattern",
      "permanent": true
    }
  ],
  "rewrites": [
    {
      "source": "/api-proxy",
      "destination": "/api/api-proxy"
    }
  ],
  "crons": [
    {
      "path": "/api/auto-content",
      "schedule": "0 8 * * *"
    }
  ]
}
