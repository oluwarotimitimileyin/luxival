{
  "entities": {
    "User": {
      "title": "User",
      "description": "System user with business details",
      "type": "object",
      "properties": {
        "businessName": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "address": { "type": "string" },
        "taxId": { "type": "string" },
        "logoUrl": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["businessName", "email"]
    },
    "Expense": {
      "title": "Expense",
      "description": "A single business expense or receipt",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "merchantName": { "type": "string" },
        "amount": { "type": "number" },
        "currency": { "type": "string" },
        "date": { "type": "string", "format": "date" },
        "category": { "type": "string" },
        "taxAmount": { "type": "number" },
        "reference": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "verified"] },
        "imageUrl": { "type": "string" },
        "source": { "type": "string", "enum": ["upload", "gmail", "drive"] },
        "isBusiness": { "type": "boolean" },
        "isRecurring": { "type": "boolean" },
        "frequency": { "type": "string", "enum": ["weekly", "monthly", "yearly"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "merchantName", "amount", "date", "status"]
    },
    "Invoice": {
      "title": "Invoice",
      "description": "A generated customer invoice",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "invoiceNumber": { "type": "string" },
        "customerId": { "type": "string" },
        "customerName": { "type": "string" },
        "customerAddress": { "type": "string" },
        "date": { "type": "string", "format": "date" },
        "dueDate": { "type": "string", "format": "date" },
        "items": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "description": { "type": "string" },
              "amount": { "type": "number" },
              "expenseId": { "type": "string" }
            }
          }
        },
        "totalAmount": { "type": "number" },
        "status": { "type": "string", "enum": ["draft", "sent", "paid"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "invoiceNumber", "customerName", "date", "totalAmount"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User business profile"
    },
    "/users/{userId}/expenses/{expenseId}": {
      "schema": "Expense",
      "description": "Individual expenses linked to a user"
    },
    "/users/{userId}/invoices/{invoiceId}": {
      "schema": "Invoice",
      "description": "Invoices generated by the user"
    }
  }
}